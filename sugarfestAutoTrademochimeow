local logCount = 0
local MAX_LOGS = 60

local LOG_COLORS = {
    info    = Color3.fromRGB(180, 180, 210),
    success = Color3.fromRGB(80, 220, 130),
    warn    = Color3.fromRGB(255, 190, 60),
    error   = Color3.fromRGB(255, 90, 90),
    state   = Color3.fromRGB(80, 200, 255),
    action  = Color3.fromRGB(200, 100, 255),
}

local LOG_ICONS = {
    info    = "·",
    success = "✓",
    warn    = "!",
    error   = "✗",
    state   = "▸",
    action  = "◆",
}

local function addLog(msg, logType)
    logType = logType or "info"
    logCount = logCount + 1

    -- Remove oldest if over limit
    local children = LogContainer:GetChildren()
    local items = {}
    for _, c in ipairs(children) do
        if c:IsA("Frame") then table.insert(items, c) end
    end
    if #items >= MAX_LOGS then
        table.remove(items, 1):Destroy()
    end

    local row = Instance.new("Frame")
    row.Size = UDim2.new(1, 0, 0, 18)
    row.BackgroundTransparency = 1
    row.LayoutOrder = logCount
    row.Parent = LogContainer

    local icon = Instance.new("TextLabel")
    icon.Size = UDim2.new(0, 14, 1, 0)
    icon.BackgroundTransparency = 1
    icon.Text = LOG_ICONS[logType] or "·"
    icon.TextColor3 = LOG_COLORS[logType]
    icon.TextSize = 11
    icon.Font = Enum.Font.GothamBold
    icon.Parent = row

    local txt = Instance.new("TextLabel")
    txt.Size = UDim2.new(1, -18, 1, 0)
    txt.Position = UDim2.new(0, 16, 0, 0)
    txt.BackgroundTransparency = 1
    txt.Text = msg
    txt.TextColor3 = LOG_COLORS[logType]
    txt.TextSize = 11
    txt.Font = Enum.Font.Gotham
    txt.TextXAlignment = Enum.TextXAlignment.Left
    txt.TextTruncate = Enum.TextTruncate.AtEnd
    txt.Parent = row

    -- Auto scroll to bottom
    task.defer(function()
        LogContainer.CanvasPosition = Vector2.new(0, math.huge)
    end)
end

