-- Helper Functions
local function feedPet(petUnique)
    UI_Log("Equipping pet: " .. tostring(petUnique), "action")
    local equipArgs = {
        [1] = petUnique,
        [2] = { use_sound_delay = true, equip_as_last = false }
    }

    local equipped = pcall(function()
        return EquipPet:InvokeServer(unpack(equipArgs))
    end)

    if equipped then
        print("✅ Equipped Pet # ", petUnique)
    else
        warn("❌ Failed to equip Pet # ", petUnique)
    end

    task.wait(3)
    local potsUnique = {}
    local counter = 0
    local ClientData = require(game:GetService("ReplicatedStorage").ClientModules.Core.ClientData)
    local foodData = ClientData.get_data()[playerName].inventory.food
    for _, potion in pairs(foodData) do
        if potion.kind == "pet_age_potion" and counter <= getgenv().PetRarity then
            table.insert(potsUnique, potion.unique)
            print("Found Potion:", potion.unique)
            counter = counter + 1
        end
    end
    local args = {
        "__Enum_PetObjectCreatorType_2",
        {
            additional_consume_uniques = {
                potsUnique[2],
                potsUnique[3],
                potsUnique[4],
                potsUnique[5],
                potsUnique[6],
                potsUnique[7]
            },
            pet_unique = petUnique,
            unique_id = potsUnique[1]
        }
    }

    local success, result = pcall(function()
        return game:GetService("ReplicatedStorage"):WaitForChild("API"):WaitForChild("PetObjectAPI/CreatePetObject"):InvokeServer(unpack(args))
    end)

    task.wait(10)
    if success then
        print("✅ Fed pet:", petUnique)
        UI_Increment("fed")
    else
        warn("❌ Failed to feed pet:", petUnique, result)
    end
end

