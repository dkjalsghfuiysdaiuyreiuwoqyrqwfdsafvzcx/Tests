-- ============================================================
--  OVERRIDE print/warn so executor output goes to UI too
-- ============================================================
local _origPrint = print
local _origWarn  = warn

getgenv().print = function(...)
    local msg = table.concat(table.pack(...), " "):gsub("\n", " ")
    _origPrint(...)
    local t = "info"
    if msg:find("✅") then t = "success"
    elseif msg:find("❌") then t = "error"
    elseif msg:find("Fusing") then t = "action"
    elseif msg:find("Found") then t = "info"
    end
    addLog(msg, t)
end

getgenv().warn = function(...)
    local msg = table.concat(table.pack(...), " "):gsub("\n", " ")
    _origWarn(...)
    addLog(msg, "warn")
end

