        end
    end)

    while not getgenv().IN_TRADE do
        task.wait(5)
        UI_Log("Sending trade request to " .. getgenv().MAIN_ACCOUNT_NAME .. "...", "info")
        game:GetService("ReplicatedStorage"):WaitForChild("API"):WaitForChild("TradeAPI/SendTradeRequest"):FireServer(
            game:GetService("Players"):WaitForChild(getgenv().MAIN_ACCOUNT_NAME)
        )
    end
end
